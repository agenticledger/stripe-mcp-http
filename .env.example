# Stripe MCP — broker-first (auth model "B"). Holds ZERO Stripe secrets.
PORT=3100

# Connections Broker install identity (from the broker's POST /register).
BROKER_BASE_URL=https://connectionsbroker.agenticledger.ai
BROKER_INSTALL_BEARER=
BROKER_JWT_KEY=
BROKER_CLIENT_NAMESPACE=

# Which broker provider row to resolve tokens for.
BROKER_PROVIDER=stripe

# 'oauth' mints a consent URL on connect-on-first-call;
# 'static' instructs an admin to vault an API key via the broker POST /credential.
BROKER_AUTH_KIND=oauth

# Optional: unforgeable principal header on the public Railway host.
# BROKER_PRINCIPAL_HMAC_KEY=
# BROKER_FALLBACK_PRINCIPAL=default
